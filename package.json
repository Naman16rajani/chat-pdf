{
	"name": "chat-pdf",
	"version": "0.0.1",
	"private": true,
	"scripts": {
		"dev": "vite dev",
		"build": "vite build",
		"preview": "vite preview",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
		"lint": "prettier --check . && eslint .",
		"format": "prettier --write .",
		"add:component": "pnpm dlx shadcn-svelte@latest add ",
		"db:typegen": "npx supabase gen types --lang=typescript --project-id 'cdwzmrydgiuaibbbklzd' --schema public > src/lib/server/db/gen-types.ts"
	},
	"devDependencies": {
		"@sveltejs/adapter-auto": "^3.0.0",
		"@sveltejs/kit": "^2.20.6",
		"@sveltejs/vite-plugin-svelte": "^3.0.0",
		"@types/eslint": "^9.6.0",
		"autoprefixer": "^10.4.20",
		"eslint": "^9.0.0",
		"eslint-config-prettier": "^9.1.0",
		"eslint-plugin-svelte": "^2.36.0",
		"globals": "^15.0.0",
		"postcss": "^8.4.41",
		"prettier": "^3.1.1",
		"prettier-plugin-svelte": "^3.1.2",
		"supabase": "^1.187.10",
		"svelte": "^4.2.7",
		"svelte-check": "^3.6.0",
		"tailwindcss": "^3.4.9",
		"typescript": "^5.0.0",
		"typescript-eslint": "^8.0.0",
		"vite": "^5.0.3"
	},
	"type": "module",
	"dependencies": {
		"@langchain/community": "^0.2.27",
		"@langchain/core": "^0.2.23",
		"@langchain/openai": "^0.2.6",
		"@supabase/ssr": "^0.4.0",
		"@supabase/supabase-js": "^2.45.1",
		"bits-ui": "^0.21.13",
		"clsx": "^2.1.1",
		"formsnap": "^1.0.1",
		"langchain": "^0.2.15",
		"lucide-svelte": "^0.427.0",
		"pdf-parse": "^1.1.1",
		"svelte-markdown": "^0.4.1",
		"sveltekit-superforms": "^2.16.1",
		"tailwind-merge": "^2.4.0",
		"tailwind-variants": "^0.2.1",
		"zod": "^3.23.8"
	},
	"resolutions": {
		"@langchain/core": "0.2.23"
	},
	"pnpm": {
		"overrides": {
			"@langchain/core": "0.2.23"
		}
	}
}
